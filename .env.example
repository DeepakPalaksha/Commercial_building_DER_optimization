# Copy this file to .env and fill in your keys before running.
# .env must never be committed to git.

# NREL Developer API key — register free at https://developer.nrel.gov/signup/
# Used by: scripts/download_data.py (PVWatts solar data)
# If left as DEMO_KEY, PVWatts still works at low request volume.
NREL_API_KEY=your_key_from_developer.nrel.gov

# Anthropic API key — get from https://console.anthropic.com/
# Used by: agents/orchestrator.py (LangGraph Claude calls)
ANTHROPIC_API_KEY=your_key_from_console.anthropic.com
